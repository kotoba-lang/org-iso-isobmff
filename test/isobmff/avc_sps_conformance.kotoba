(ns isobmff.avc-sps-conformance
  (:require [isobmff.avc-sps :as avc])
  (:export [main fixture-check reject-check]))

(def sps-type
  [:record :h264/sps
   [[:profile-idc :i64] [:level-idc :i64] [:width :i64] [:height :i64]
    [:frame-mbs-only :bool] [:chroma-format-idc :i64]
    [:pic-order-cnt-type :i64]]])
(def sps-result-type [:result [:alias sps-type] :keyword])

(defn fixture-check [data :vector-i64] :i64
  (match-result (avc/parse-baseline-sps data) sps-result-type
    (ok parsed
      (if (= 66 (record-get sps-type parsed :profile-idc))
        (if (= 64 (record-get sps-type parsed :width))
          (if (= 48 (record-get sps-type parsed :height)) 42 3)
          2)
        1))
    (err reason 90)))

(defn reject-check [data :vector-i64] :i64
  (match-result (avc/parse-baseline-sps data) sps-result-type
    (ok unexpected 1)
    (err reason 42)))

(defn main [] :i64
  (match-result (avc/parse-baseline-sps
                  (vector-i64 0 0 0 8 102 116 121 112)) sps-result-type
    (ok unexpected 1)
    (err reason (if (= reason :required-box-missing) 42 2))))
