(ns isobmff.bounded-box-conformance
  (:require [isobmff.bounded-box :as box])
  (:export [main fixture-check]))

(def summary-type
  [:record :isobmff/top-level
   [[:box-count :i64] [:has-ftyp :bool] [:has-moov :bool] [:has-mdat :bool]
    [:media-start :i64] [:media-size :i64]]])
(def parse-result-type [:result [:alias summary-type] :keyword])

(defn expected-error? [data :vector-i64 expected :keyword] :bool
  (match-result (box/parse-top-level data) parse-result-type
    (ok unexpected false)
    (err reason (if (= reason expected) true false))))

(defn fixture-check [data :vector-i64] :i64
  (box/fixture-check data))

(defn main [] :i64
  (let [minimal
        (vector-i64
          0 0 0 8 102 116 121 112
          0 0 0 8 109 111 111 118
          0 0 0 8 109 100 97 116)]
    (match-result (box/parse-top-level minimal) parse-result-type
      (ok summary
        (if (= 3 (record-get summary-type summary :box-count))
          (if (expected-error? (vector-i64 0 0 0) :truncated-header)
            (if (expected-error?
                  (vector-i64 0 0 0 7 102 116 121 112) :invalid-box-size)
              (if (expected-error?
                    (vector-i64 0 0 0 12 102 116 121 112) :box-out-of-range)
                (if (expected-error?
                      (vector-i64 0 0 0 8 102 116 121 256) :invalid-byte)
                  (if (expected-error?
                        (vector-i64 0 0 0 1 102 116 121 112
                          0 0 0 1 0 0 0 8) :box-size-too-large)
                    42 6)
                  5)
                4)
              3)
            2)
          1))
      (err reason 90))))
