(ns isobmff.image-meta-conformance
  (:require [isobmff.image-meta :as image-meta])
  (:export [main fixture-check metadata-check reject-check]))

(def image-meta-type
  [:record :isobmff/image-meta
   [[:major-brand-code :i64] [:width :i64] [:height :i64]]])
(def image-meta-result-type
  [:result [:alias image-meta-type] :keyword])

(defn fixture-check [data :vector-i64] :i64
  (match-result (image-meta/parse-bounded data) image-meta-result-type
    (ok metadata
      (if (= 1635150182 (record-get image-meta-type metadata :major-brand-code))
        (if (= 320 (record-get image-meta-type metadata :width))
          (if (= 240 (record-get image-meta-type metadata :height)) 42 3)
          2)
        1))
    (err reason 90)))

(defn reject-check [data :vector-i64] :i64
  (match-result (image-meta/parse-bounded data) image-meta-result-type
    (ok unexpected 1)
    (err reason 42)))

(defn metadata-check
  [data :vector-i64 expected-brand :i64 expected-width :i64 expected-height :i64]
  :i64
  (match-result (image-meta/parse-bounded data) image-meta-result-type
    (ok metadata
      (if (= expected-brand (record-get image-meta-type metadata :major-brand-code))
        (if (= expected-width (record-get image-meta-type metadata :width))
          (if (= expected-height (record-get image-meta-type metadata :height)) 42 3)
          2)
        1))
    (err reason 90)))

(defn main [] :i64
  (fixture-check
    (vector-i64
      0 0 0 20 102 116 121 112 97 118 105 102 0 0 0 0 97 118 105 102
      0 0 0 48 109 101 116 97 0 0 0 0
      0 0 0 36 105 112 114 112
      0 0 0 28 105 112 99 111
      0 0 0 20 105 115 112 101 0 0 0 0
      0 0 1 64 0 0 0 240)))
